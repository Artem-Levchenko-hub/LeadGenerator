# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# App settings
APP_SECRET=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./data/leads.db

# Basic auth (для продажников, до 5 пользователей)
# Формат: user1:password1,user2:password2
AUTH_USERS=admin:admin123,sales1:change-me

# Pipeline settings
HH_CITIES=1,2,3,4,38,113      # Москва, СПб, Екб, Новосибирск, Казань, Ростов
HH_EXCLUDE_INDUSTRIES=7       # ID индустрии "Информационные технологии"
PIPELINE_INTERVAL_MINUTES=15  # как часто запускается сбор
LEADS_PER_RUN=10              # сколько лидов обрабатывать за один прогон
CLAUDE_MODEL=claude-sonnet-4-6

# Optional: Timezone
TZ=Europe/Moscow
