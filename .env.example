# ============================================================
# Stenvik Lead Pipeline + Agent Studio — переменные окружения
# Скопируй: cp .env.example .env  и заполни.
# ============================================================

# ===== App =====
APP_SECRET=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./data/leads.db
TZ=Europe/Moscow
# Учётные пары для HTTP Basic Auth дашборда (через запятую):
AUTH_USERS=admin:change-me

# ===== REMOTE-режим run.py (если запускаешь Hunter из локального /loop, а
# результаты шлёшь на сервер lead-generator.ru через REST API) =====
STENVIK_API_URL=https://lead-generator.ru
STENVIK_API_TOKEN=
INGEST_TOKEN=

# ============================================================
# === Агентная студия (worker, agents, channels) =============
# ============================================================

# === LLM-провайдер ===
# Авто-детект: если openrouter_api_key задан — используем OpenRouter,
# иначе anthropic_api_key. Можно явно задать llm_provider=openrouter|anthropic|openai.
LLM_PROVIDER=

# OpenRouter — рекомендуется для РФ (оплата картой через bothub/proxyapi).
# Один ключ → любая модель: deepseek, claude, gpt, gemini, qwen.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Anthropic-нативный путь (sk-ant-... или прокси типа aihubmix sk-hub-...).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# HTTP(S)/SOCKS5 прокси для исходящих — нужен на VPS в РФ, т.к. api.openrouter.ai
# и api.anthropic.com могут быть недоступны.
HTTP_PROXY_URL=

# Модели по ролям. Имена должны соответствовать провайдеру:
#   OpenRouter: "deepseek/deepseek-chat", "anthropic/claude-haiku-4-5", "openai/gpt-5-mini"
#   Anthropic native: "claude-sonnet-4-6", "claude-haiku-4-5"
MODEL_DEFAULT=deepseek/deepseek-chat
MODEL_PREMIUM=anthropic/claude-sonnet-4-6
DAILY_LLM_BUDGET_USD=20

# === Hunter — источники лидов ===
# 2GIS Catalog API (https://dev.2gis.ru/instruments/catalog/) — бесплатный тариф.
TWOGIS_API_KEY=
TWOGIS_CITIES=Москва,Санкт-Петербург,Краснодар,Казань,Новосибирск,Екатеринбург
TWOGIS_CATEGORIES=стоматология,автосервис,юристы,бухгалтерия,строительство,красота,клиника
# HH.ru — вторичный источник, через /loop из Claude Code.
HH_CITIES=1,2,3,4,38,113
HH_EXCLUDE_INDUSTRIES=7
LEADS_PER_RUN=10

# === Email (UniSender SMTP+IMAP, или любой стандартный) ===
SMTP_HOST=smtp.unisender.com
SMTP_PORT=465
SMTP_USER=outreach@stenvik.studio
SMTP_PASSWORD=
SMTP_FROM_EMAIL=outreach@stenvik.studio
SMTP_FROM_NAME=Stenvik
IMAP_HOST=imap.unisender.com
IMAP_PORT=993
IMAP_USER=outreach@stenvik.studio
IMAP_PASSWORD=

# === Telegram bot ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=stenvik_studio_bot

# === SMS via smsc.ru ===
SMSC_LOGIN=
SMSC_PASSWORD=

# === Voice via Zvonok.com ===
ZVONOK_API_KEY=
ZVONOK_CAMPAIGN_ID=

# === Дневные лимиты исходящих (safety rails) ===
DAILY_EMAIL_LIMIT=30
DAILY_TELEGRAM_LIMIT=100
DAILY_SMS_LIMIT=50
DAILY_CALL_LIMIT=0
# Холодильник outbox — секунды между записью драфта и реальной отправкой.
OUTBOX_HOLDING_SECONDS=600
# Loop guard: после скольких ботских реплик подряд эскалировать человеку.
CONVERSATION_LOOP_GUARD_MSGS=5
# Максимум tool-итераций за один запуск Outreach Agent. 8 хватает: fetch_site
# + dns_check + 3-4 record_weakness + draft_message + finish. Если упёрся —
# escalate_to_human лучше чем крутить цикл.
OUTREACH_MAX_ITERATIONS=8

# === Yandex Disk (legacy LOCAL-режим, не используется в агентной студии) ===
YANDEX_DISK_TOKEN=
YANDEX_DISK_FILE_PATH=/Stenvik/leads.xlsx
