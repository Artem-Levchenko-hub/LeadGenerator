# ===== Yandex Disk (куда пишем готовые лиды в виде xlsx-таблицы) =====
# 1. Создай OAuth-приложение: https://oauth.yandex.ru/client/new
#    (права: cloud_api:disk.read, cloud_api:disk.write)
# 2. Получи токен: https://oauth.yandex.ru/authorize?response_type=token&client_id=ТВОЙ_CLIENT_ID
YANDEX_DISK_TOKEN=y0_...
# Путь к xlsx-файлу на Я.Диске. Если файла нет — создастся при первой записи.
YANDEX_DISK_FILE_PATH=/Stenvik/leads.xlsx

# ===== App =====
APP_SECRET=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./data/leads.db

# ===== Pipeline =====
HH_CITIES=1,2,3,4,88,76      # Москва, СПб, Екб, Новосибирск, Казань, Ростов
HH_EXCLUDE_INDUSTRIES=7       # ID индустрии "Информационные технологии"
LEADS_PER_RUN=5               # сколько кандидатов собирать за один тик /loop

# Optional: Timezone
TZ=Europe/Moscow

# ===== Deprecated (не используется при агент-режиме через /loop) =====
# ANTHROPIC_API_KEY=
# AUTH_USERS=admin:admin123
# CLAUDE_MODEL=claude-sonnet-4-6
